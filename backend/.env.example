# Backend environment variables (set these in Render, or export locally).
# Spring Boot maps these automatically via relaxed binding.

# JDBC URL of your MySQL database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/insurance_db?createDatabaseIfNotExist=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=changeme

# Allowed frontend origins (comma-separated) for CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

# JWT signing key — use a long random string (32+ characters) in production
APP_JWT_SECRET=ims-secret-key-change-me-in-production-0123456789

# Port (Render injects this automatically; default 8081 locally)
PORT=8081
