@startuml 01-use-case-diagram
!pragma layout smetana
title Insurance Management System - Use Case Diagram
left to right direction
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor #EAF2F8
  BorderColor #2E75B6
}

actor Customer as C
actor Agent as A
actor Admin as AD

rectangle "Insurance Management System" {
  usecase "Register / Login" as UC1
  usecase "Browse Insurance Plans\n(Life / Health / Motor / Home)" as UC2
  usecase "Apply for Policy" as UC3
  usecase "Pay Premium (Simulated)" as UC4
  usecase "File Claim" as UC5
  usecase "Track Policy & Claim Status" as UC6
  usecase "View Notifications" as UC7
  usecase "Approve / Reject Policy" as UC8
  usecase "Review Claims" as UC9
  usecase "Manage Assigned Customers" as UC10
  usecase "Manage Users & Agents" as UC11
  usecase "Manage Insurance Plans" as UC12
  usecase "Assign Agent to Customer" as UC13
  usecase "Settle Claims (Final Decision)" as UC14
  usecase "View Dashboard & Reports" as UC15
}

C --> UC1
C --> UC2
C --> UC3
C --> UC4
C --> UC5
C --> UC6
C --> UC7

A --> UC1
A --> UC2
A --> UC8
A --> UC9
A --> UC10
A --> UC7
A --> UC15

AD --> UC1
AD --> UC11
AD --> UC12
AD --> UC13
AD --> UC8
AD --> UC14
AD --> UC15
@enduml
